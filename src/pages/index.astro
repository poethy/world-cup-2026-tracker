---
import RootLayout from '../layouts/RootLayout.astro';
import { COUNTRIES, FIFA_TO_ISO } from '../data/album-structure';
---

<RootLayout title="World Cup 2026 Tracker">
  <div class="app">
    <!-- Top bar -->
    <header class="topbar">
      <div class="topbar__left">
        <a href="/" class="logo" aria-label="Tracker 26 — Home">
          <div class="logo__mark">
            <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
              <circle cx="16" cy="16" r="14.5" fill="none" stroke="var(--ink)" stroke-width="1.2"/>
              <circle cx="16" cy="16" r="1.8" fill="var(--accent)"/>
              <path d="M2 16 H30 M16 2 V30" stroke="var(--ink)" stroke-width="0.6" opacity="0.35"/>
              <path d="M6 16 a10 10 0 0 1 20 0" stroke="var(--ink)" stroke-width="0.6" fill="none" opacity="0.35"/>
            </svg>
          </div>
          <div class="logo__text">
            Tracker 26
          </div>
        </a>

        <nav class="topbar__nav" id="logged-in-nav" style="display:none">
          <a href="/" class="is-active">Overview</a>
          <a href="/tracker">Tracker</a>
        </nav>
      </div>

      <div class="topbar__right">
        <div class="user-chip" id="user-chip" style="display:none">
          <span class="user-chip__avatar" id="user-avatar">?</span>
          <span class="user-chip__name" id="user-name">User</span>
        </div>
        <button class="btn btn--ghost" id="btn-logout" style="display:none">Sign out</button>
        <a href="/auth/login" class="btn btn--primary" id="signin-btn">Sign in</a>
      </div>
    </header>

    <div class="home">
      <!-- Hero -->
      <section class="home__hero">
        <div class="home__eyebrow-row">
          <span class="pill">Unofficial · Open-source</span>
          <span class="pill">Edition 26 · 980 stickers</span>
        </div>

        <h1 class="home__headline">
          Track every <span style="color:var(--accent)">sticker</span>,<br>finish every page.
        </h1>

        <p class="home__lede">
          A clean, fast tracker for your World Cup 2026 sticker album.
          Mark what you have, see what's missing, and never buy a duplicate again.
          Designed for collectors, not for ads.
        </p>

        <div class="home__cta-row">
          <a href="/tracker" class="btn btn--primary btn--lg" id="cta-open-album" style="display:none">
            Open your album →
          </a>
          <a href="/auth/login" class="btn btn--primary btn--lg" id="cta-start-tracking">
            Start tracking
          </a>
          <a href="/tracker" class="btn btn--lg">
            Browse the album
          </a>
        </div>
      </section>

      <!-- Numbers band -->
      <div class="home__stats">
        <div class="home__stat">
          <span class="home__stat-num">980</span>
          <span class="home__stat-label">Stickers in edition</span>
        </div>
        <div class="home__stat">
          <span class="home__stat-num">48</span>
          <span class="home__stat-label">National teams</span>
        </div>
        <div class="home__stat">
          <span class="home__stat-num">3</span>
          <span class="home__stat-label">Host countries</span>
        </div>
        <div class="home__stat">
          <span class="home__stat-num" id="stat-progress">24h</span>
          <span class="home__stat-label" id="stat-progress-label">Free, always</span>
        </div>
      </div>

      <!-- Features -->
      <section class="home__features">
        <article class="feature">
          <span class="feature__num">01</span>
          <h3 class="feature__title">Sticker-by-sticker tracking</h3>
          <p class="feature__body">
            Tap to mark owned. Filter by country, owned, or missing.
            Your progress syncs across devices the moment you sign in.
          </p>
        </article>
        <article class="feature">
          <span class="feature__num">02</span>
          <h3 class="feature__title">Smart missing list</h3>
          <p class="feature__body">
            See which teams are closest to complete, sort by gaps,
            and export a clean shopping list before your next swap meet.
          </p>
        </article>
        <article class="feature">
          <span class="feature__num">03</span>
          <h3 class="feature__title">Open-source API</h3>
          <p class="feature__body">
            Access the complete 980-sticker catalog via our public REST API.
            Build your own app or integrate with existing tools.
          </p>
        </article>
      </section>

      <!-- Teams strip -->
      <section class="home__teams">
        <header class="home__teams-head">
          <h2>All 48 nations</h2>
          <span class="eyebrow">FIFA World Cup 2026</span>
        </header>
        <div class="home__teams-grid">
          {COUNTRIES.map(c => {
            const iso = FIFA_TO_ISO[c.code];
            return (
            <a href={`/tracker?section=${c.code}`} class="team-pill">
              {iso ? (
                <span
                  class={`fi fi-${iso}`}
                  style="display:inline-block;width:36px;height:24px;flex-shrink:0;border-radius:3px;background-size:cover;background-position:center;vertical-align:middle"
                  title={c.name}
                  aria-label={c.name}
                ></span>
              ) : (
                <div
                  class={`flag flag--${c.dir}`}
                  style="width:36px;height:24px;flex-shrink:0"
                  title={c.name}
                  aria-label={c.name}
                >
                  <span style={`background:${c.stripes[0]}`}></span>
                  <span style={`background:${c.stripes[1]}`}></span>
                  <span style={`background:${c.stripes[2]}`}></span>
                </div>
              )}
              <div style="display:flex;flex-direction:column;gap:2px">
                <span class="team-pill__name">{c.name}</span>
                <span class="team-pill__code">{c.code} · {c.region}{c.host ? ' · HOST' : ''}</span>
              </div>
            </a>
            );
          })}
        </div>
      </section>
    </div>
  </div>
</RootLayout>

<script>
  import { supabase } from '../utils/supabase';

  supabase.auth.getSession().then(({ data: { session } }) => {
    if (!session) return;

    const name = session.user.user_metadata?.full_name
      || session.user.email?.split('@')[0]
      || 'User';
    const initial = name.charAt(0).toUpperCase();

    const chip = document.getElementById('user-chip');
    if (chip) chip.style.display = 'flex';
    const avatar = document.getElementById('user-avatar');
    if (avatar) avatar.textContent = initial;
    const userName = document.getElementById('user-name');
    if (userName) userName.textContent = name;

    const nav = document.getElementById('logged-in-nav');
    if (nav) nav.style.display = 'flex';

    const signinBtn = document.getElementById('signin-btn');
    if (signinBtn) signinBtn.style.display = 'none';

    const logoutBtn = document.getElementById('btn-logout');
    if (logoutBtn) {
      logoutBtn.style.display = 'inline-flex';
      logoutBtn.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/auth/login';
      });
    }

    const ctaStart = document.getElementById('cta-start-tracking');
    if (ctaStart) ctaStart.style.display = 'none';
    const ctaOpen = document.getElementById('cta-open-album');
    if (ctaOpen) ctaOpen.style.display = 'inline-flex';

    // Load collection count — direct Supabase call (no server proxy)
    supabase
      .from('user_stickers')
      .select('sticker_id', { count: 'exact', head: true })
      .eq('user_id', session.user.id)
      .then(({ count }) => {
        if (count != null) {
          const pct = Math.round((count / 980) * 100);
          const el = document.getElementById('stat-progress');
          const lbl = document.getElementById('stat-progress-label');
          if (el) el.textContent = `${pct}%`;
          if (lbl) lbl.textContent = 'Your progress';
        }
      })
      .catch(() => {});
  });
</script>
