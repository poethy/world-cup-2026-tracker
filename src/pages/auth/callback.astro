---
// OAuth callback page — Supabase redirects here after Google login.
// The Supabase client auto-detects the session from the URL hash/code.
import RootLayout from '../../layouts/RootLayout.astro';
---

<RootLayout title="Signing in…">
  <div class="callback">
    <div class="callback__inner">
      <div class="callback__logo">
        <svg viewBox="0 0 32 32" width="32" height="32" aria-hidden="true">
          <circle cx="16" cy="16" r="14.5" fill="none" stroke="var(--ink)" stroke-width="1.2"/>
          <circle cx="16" cy="16" r="1.8" fill="var(--accent)"/>
          <line x1="16" y1="1.5" x2="16" y2="5"  stroke="var(--accent)" stroke-width="1.2"/>
          <line x1="16" y1="27"  x2="16" y2="30.5" stroke="var(--ink-2)" stroke-width="1.2"/>
          <line x1="1.5" y1="16" x2="5"  y2="16" stroke="var(--ink-2)" stroke-width="1.2"/>
          <line x1="27"  y1="16" x2="30.5" y2="16" stroke="var(--ink-2)" stroke-width="1.2"/>
        </svg>
        <span class="callback__wordmark mono">ALBUM<span style="color:var(--accent)">26</span></span>
      </div>
      <div class="callback__spinner" aria-hidden="true"></div>
      <p class="callback__msg mono">SIGNING IN…</p>
    </div>
  </div>

  <style>
    .callback {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg);
    }
    .callback__inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 24px;
    }
    .callback__logo {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .callback__wordmark {
      font-size: 16px;
      font-weight: 600;
      letter-spacing: 0.12em;
      color: var(--ink);
    }
    .callback__spinner {
      width: 36px;
      height: 36px;
      border: 2px solid var(--surface-2);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.75s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .callback__msg {
      font-size: 11px;
      letter-spacing: 0.14em;
      color: var(--muted);
      margin: 0;
    }
  </style>

  <script>
    import { supabase } from '../../utils/supabase';

    const { data: { session } } = await supabase.auth.getSession();

    if (session) {
      window.location.replace('/tracker');
    } else {
      const { data: { subscription } } = supabase.auth.onAuthStateChange((event, session) => {
        if (event === 'SIGNED_IN' && session) {
          subscription.unsubscribe();
          window.location.replace('/tracker');
        }
      });
      setTimeout(() => window.location.replace('/auth/login?error=timeout'), 3000);
    }
  </script>
</RootLayout>
